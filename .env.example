# Root environment for docker-compose

POSTGRES_DB=stockpilot_oms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stockpilot_oms
JWT_SECRET_KEY=change-me-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_ORIGIN_REGEX=
