APP_NAME=StockPilot OMS API
API_PREFIX=/api/v1
DEBUG=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockpilot_oms
DATABASE_MIN_POOL_SIZE=1
DATABASE_MAX_POOL_SIZE=10

JWT_SECRET_KEY=change-me-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
